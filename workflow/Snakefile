import os
os.environ["GKSwstype"] = "100"

rule all:
    input:
        julia_instantiated="tmp/julia_ready",
        h5file="data_assets/isospin1_corr.hdf5",
        h5file_eig="data_assets/isospin1_eigenvalues.hdf5",
        h5file_fit="data_assets/isospin1_fitresults.hdf5",
        h5file_out="data_assets/isospin1_fitresults_full.hdf5",
        h5file_eig_gevp_evp="data_assets/isospin1_eigenvalues_evp_gevp.hdf5",
        h5file_fit_gevp_evp="data_assets/isospin1_fitresults_evp_gevp.hdf5",
        plots2x2="assets/plots/diagrams.pdf",
        plots3x3="assets/plots/diagrams_3x3.pdf",
        table_fit="assets/tables/fit_results_3x3_tuned.csv",
        plot_eig="assets/plots/eigenvalues.pdf",
        plot_eig_evp_vs_gvp="assets/plots/eigenvalues_evp_gevp.pdf",
        plot_eig_fits="assets/plots/eigenvalues_with_fit.pdf",
        plot_cmat_elements="assets/plots/correlation_matrix_elements.pdf",
        plot_meson_correlators="assets/plots/meson_correlators.pdf",
        plot_meff_gevp="assets/plots/effective_masses_(g)evp.pdf",
        plot_meff_mesons="assets/plots/effective_masses_mesons.pdf",
        plot_meff_mesons_p0="assets/plots/effective_masses_mesons_p0.pdf",
        plot_meff_comparison_gevp="assets/plots/effective_masses_comparison_(g)evp.pdf",


rule julia_instantiate:
    input:
        script="src/scripts_julia/instantiate.jl",
    output:
        julia_instantiated="tmp/julia_ready",
    conda: 
        "environment.yml"
    shell:
        "julia {input.script} && touch {output.julia_instantiated}"


rule parse_logs:
    input:
        script="src/scripts_julia/parse_all_files.jl",
        julia_instantiated="tmp/julia_ready",
        metadata="metadata/input_files.csv",
    output:
        h5file="data_assets/isospin1_sorted.hdf5",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --path raw_data/ --h5file {output.h5file} --inputfiles {input.metadata}'


rule ensembles_tables:
    input:
        script="src/scripts_julia/write_tables.jl",
        julia_instantiated="tmp/julia_ready",
        h5file="data_assets/isospin1_sorted.hdf5",
        metadata="metadata/ensembles.csv"
    output:
        table="assets/tables/analysed_runs.csv"
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file {input.h5file} --ensembles_list {input.metadata} --outfile {output.table}'


rule combine_runs_hdf5:
    input:
        script="src/scripts_julia/combine_runs.jl",
        julia_instantiated="tmp/julia_ready",
        h5file_in="data_assets/isospin1_sorted.hdf5",
    output:
        h5file_out="data_assets/isospin1_merged.hdf5",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file_in {input.h5file_in} --h5file_out {output.h5file_out}'


rule correlation_matrix:
    input:
        script="src/scripts_julia/write_correlation_matrix.jl",
        julia_instantiated="tmp/julia_ready",
        h5file_in="data_assets/isospin1_merged.hdf5",
        metadata="metadata/ensembles.csv"
    output:
        h5file_out="data_assets/isospin1_corr.hdf5",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file_in {input.h5file_in} --h5file_out {output.h5file_out} --ensembles_list {input.metadata}'


rule write_eigenvalues:
    input:
        script="src/scripts_julia/write_eigenvalues.jl",
        julia_instantiated="tmp/julia_ready",
        h5file_in="data_assets/isospin1_corr.hdf5",
        metadata="metadata/pipi_fitintervals.csv",
    output:
        h5file_out="data_assets/isospin1_eigenvalues.hdf5",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file_in {input.h5file_in} --h5file_out {output.h5file_out}  --metadata {input.metadata} --avg true'


rule write_eigenvalues_evp_vs_gevp:
    input:
        script="src/scripts_julia/write_eigenvalues.jl",
        julia_instantiated="tmp/julia_ready",
        h5file_in="data_assets/isospin1_corr.hdf5",
        metadata="metadata/pipi_fitintervals_evp_gevp.csv",
        swaps="metadata/swaps.csv",
    output:
        h5file_out="data_assets/isospin1_eigenvalues_evp_gevp.hdf5",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file_in {input.h5file_in} --h5file_out {output.h5file_out}  --metadata {input.metadata}  --swap_metadata {input.swaps} --avg true'


rule fit_eigenvalues:
    input:
        script="src/src_py/fitting_eigenvalues.py",
        metadata="metadata/pipi_fitintervals{label}.csv",
        h5file_in="data_assets/isospin1_eigenvalues{label}.hdf5",
    output:
        h5file_out="data_assets/isospin1_fitresults{label}.hdf5",
    conda:
        "environment.yml"
    shell:
        'python3 {input.script} {input.h5file_in} {output.h5file_out} {input.metadata}'


rule fit_mesons:
    input:
        script="src/src_py/fitting_mesons.py",
        metadata="metadata/pipi_fitintervals_mesons.csv",
        h5file_eig="data_assets/isospin1_eigenvalues.hdf5",
        h5file_fit_pipi="data_assets/isospin1_fitresults.hdf5",
    output:
        h5file_out="data_assets/isospin1_fitresults_full.hdf5",
    conda:
        "environment.yml"
    shell:
        '''
        cp {input.h5file_eig} {output.h5file_out}
        python3 {input.script} {input.h5file_in} {output.h5file_out} {input.metadata}
        '''


rule fit_result_table:
    input:
        script="src/scripts_julia/write_table_fitresults.jl",
