rule plot_effective_masses:
    input:
        script="src/scripts_julia/plot_effective_masses.jl",
        h5file_eig="data_assets/isospin1_eigenvalues.hdf5",
        h5file_fit="data_assets/isospin1_fitresults_full.hdf5",
        fitparam="metadata/pipi_fitintervals.csv",
        infinite_volume="metadata/infinite_volume.csv",
    output:
        plot_gevp="assets/plots/effective_masses_(g)evp.pdf",
        plot_mesons="assets/plots/effective_masses_mesons.pdf",
        plot_mesons_p0="assets/plots/effective_masses_mesons_p0.pdf",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file_eig {input.h5file_eig} --h5file_fit {input.h5file_fit} --infinite_volume {input.infinite_volume} --metadata {input.fitparam} --plotpath "assets/plots" --plot_mesons true --plotbasename "effective_masses"'


rule plot_effective_masses_comparison:
    input:
        script="src/scripts_julia/plot_effective_masses.jl",
        h5file_eig="data_assets/isospin1_eigenvalues_evp_gevp.hdf5",
        h5file_fit="data_assets/isospin1_fitresults_evp_gevp.hdf5",
        fitparam="metadata/pipi_fitintervals_evp_gevp.csv",
        infinite_volume="metadata/infinite_volume.csv",
    output:
        plot_gevp="assets/plots/effective_masses_comparison_(g)evp.pdf",
    conda:
        "environment.yml"
    shell:
        'julia {input.script} --h5file_eig {input.h5file_eig} --h5file_fit {input.h5file_fit} --infinite_volume {input.infinite_volume} --metadata {input.fitparam} --plotpath "assets/plots" --plot_mesons false --plotbasename "effective_masses_comparison"'


